{
  "schema_version": "0.1.0",
  "id": "action-state-bridges-v0",
  "name": "Action/State Bridge Logic Profile",
  "status": "draft",
  "source_papers": [
    "doi:10.1007/s11225-017-9716-1"
  ],
  "meta_logic": "lean4-dependent-type-theory",
  "object_language": {
    "kind": "action-state-bridge",
    "primitive_sorts": [
      "Situation",
      "ActionStep",
      "State"
    ],
    "primitive_symbols": [
      "requiredAction",
      "forbiddenAction",
      "requiredState",
      "forbiddenState",
      "realizes",
      "avoids"
    ]
  },
  "consequence_relation": {
    "name": "typed action/state bridge derivability",
    "representation": "abstract-entailment",
    "notes": "The profile keeps action and state propositions in separate types and connects them only through explicit bridge principles."
  },
  "metalogical_properties": [
    {
      "id": "separate_action_state_syntax",
      "status": "represented",
      "description": "Action obligations range over predicates on action steps; state obligations range over predicates on states."
    },
    {
      "id": "bridge_principles",
      "status": "represented",
      "description": "State obligations and prohibitions can induce action obligations and prohibitions only through explicit realization/avoidance bridges."
    }
  ],
  "normative_systems": [
    {
      "id": "action_obligation_frame",
      "status": "represented",
      "description": "Required and forbidden action predicates are stored per situation."
    },
    {
      "id": "state_obligation_frame",
      "status": "represented",
      "description": "Required and forbidden state predicates are stored per situation."
    },
    {
      "id": "most_specific_obligation_candidate",
      "status": "represented",
      "description": "Binary agglomeration and trimming yield more specific required action candidates."
    },
    {
      "id": "most_general_prohibition_candidate",
      "status": "represented",
      "description": "Forbidden-action agglomeration yields a more general forbidden action candidate."
    },
    {
      "id": "contractor_scenario",
      "status": "represented",
      "description": "A contract requires work completion, safety forbids unsafe work, and trimming derives the required safe completion action."
    }
  ],
  "permission_families": [
    {
      "id": "not_in_scope",
      "status": "scoped-out",
      "description": "This profile focuses on obligations, prohibitions, and bridges rather than permission families."
    }
  ],
  "formalization_targets": [
