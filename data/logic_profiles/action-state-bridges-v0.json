    {
      "id": "contractor_example",
      "source": "doi:10.1007/s11225-017-9716-1",
      "status": "represented",
      "reason": "Represented as a concrete Lean scenario deriving safe completion from a required state and an unsafe-action prohibition."
    }
  ],
