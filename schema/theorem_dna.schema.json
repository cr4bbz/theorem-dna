{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TheoremDNA",
  "type": "object",
  "required": [
    "id",
    "kind",
    "source_dna",
    "logic_dna",
    "formula_dna",
    "context_dna",
    "dependency_dna",
    "proofs"
  ],
  "properties": {
    "id": { "type": "string" },
    "kind": {
      "type": "string",
      "enum": ["axiom", "definition", "lemma", "theorem", "corollary"]
    },
    "source_dna": { "type": "string" },
    "informal_dna": { "type": "string" },
    "logic_dna": { "type": "string" },
    "formula_dna": { "type": "string" },
    "context_dna": { "type": "string" },
    "dependency_dna": { "type": "string" },
    "proofs": {
      "type": "object",
      "properties": {
        "lean4": { "$ref": "#/$defs/proof" },
        "isabelle_hol": { "$ref": "#/$defs/proof" },
        "rocq": { "$ref": "#/$defs/proof" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "proof": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_attempted", "failed", "checked"]
        },
        "statement_hash": { "type": "string" },
        "proof_hash": { "type": "string" },
        "environment_hash": { "type": "string" },
        "verified_at": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
