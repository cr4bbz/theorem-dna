{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theorem-dna.org/schema/paper.schema.json",
  "title": "Source Paper",
  "type": "object",
  "required": [
    "id",
    "title",
    "authors",
    "year",
    "doi",
    "journal",
    "priority",
    "formalization_strategy",
    "targets"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "year": {
      "type": "integer",
      "minimum": 1900
    },
    "doi": {
      "type": "string",
      "pattern": "^10\\."
    },
    "journal": {
      "type": "string"
    },
    "priority": {
      "enum": [
        "P0",
        "P1",
        "reference"
      ]
    },
    "formalization_strategy": {
      "enum": [
        "formalize",
        "formalize-slice",
        "integrate-upstream"
      ]
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
