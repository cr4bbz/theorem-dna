{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theorem-dna.org/schema/ledger_event.schema.json",
  "title": "Ledger Event v0.1",
  "type": "object",
  "required": [
    "schema_version",
    "event_type",
    "target",
    "payload_hash",
    "timestamp",
    "actor",
    "event_hash"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "GENESIS",
        "PROOF_VERIFIED",
        "COROLLARY_ACCEPTED"
      ]
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "previous_event_hash": {
      "oneOf": [
        {
          "$ref": "#/$defs/sha256"
        },
        {
          "type": "null"
        }
      ]
    },
    "payload_hash": {
      "$ref": "#/$defs/sha256"
    },
    "event_hash": {
      "$ref": "#/$defs/sha256"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  },
  "additionalProperties": false
}
