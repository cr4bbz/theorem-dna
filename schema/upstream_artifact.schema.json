{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theorem-dna.org/schema/upstream_artifact.schema.json",
  "title": "Upstream Formalization Artifact",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "name",
    "source_paper",
    "artifact_type",
    "prover",
    "upstream_environment",
    "locator",
    "claims",
    "integration_targets",
    "verification"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "source_paper": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "type": "string",
      "enum": ["external-proof-environment", "external-proof-library"]
    },
    "prover": {
      "type": "string",
      "enum": ["rocq", "coq"]
    },
    "upstream_environment": {
      "type": "object",
      "required": ["assistant", "version"],
      "properties": {
        "assistant": {
          "type": "string",
          "enum": ["Coq/Rocq", "Rocq", "Coq"]
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "locator": {
      "type": "object",
      "required": ["status", "source"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["located", "pending"]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "revision": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "integration_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "verification": {
      "type": "object",
      "required": ["status", "checks"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["registered", "local-checkout-verified", "failed"]
        },
        "checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/check"
          }
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "claim": {
      "type": "object",
      "required": ["id", "status", "description"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]*$"
        },
        "status": {
          "type": "string",
          "enum": ["source-described", "pending", "verified", "scoped-out"]
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "check": {
      "type": "object",
      "required": ["id", "status", "description"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]*$"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "passed", "failed", "not_attempted"]
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
